# Seoul Fit Backend 환경변수 예제
# 값은 의도적으로 비워 두었습니다. 실제 자격증명을 커밋하지 마세요.

# local | dev | prod (개발자 기본 실행은 local 권장)
SPRING_PROFILES_ACTIVE=
SERVER_PORT=
TZ=

# dev/prod PostgreSQL 필수 값. URL 예: jdbc:postgresql://host:5432/database
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# 허용할 프론트엔드 오리진의 쉼표 구분 목록(와일드카드 금지)
CORS_ALLOWED_ORIGINS=

# 서울시 공공데이터 API
SEOUL_API_KEY=

# OAuth (dev/prod 필수, redirect URI 포함)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=

# 기타 외부 API와 JWT
GOOGLE_API_KEY=
JWT_SECRET=
JWT_ACCESS_EXPIRY=
JWT_REFRESH_EXPIRY=

# 공통 선택 설정
GEO_CSV_PATH=

# 별도 notification 프로파일을 사용할 때만 필요한 선택 값
FCM_SERVER_KEY=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=
